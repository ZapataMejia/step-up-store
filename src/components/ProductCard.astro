---
import type { Product } from "../data/products";
import { formatPrice, PLACEHOLDER, isOnPromo, discountPercent, productType } from "../data/products";
import { productWhatsappUrl } from "../lib/whatsapp";

interface Props {
  product: Product;
  productUrl?: string;
}

const { product, productUrl } = Astro.props;
const onPromo = isOnPromo(product);
const priceLabel = onPromo ? formatPrice(product.promoPrice as number) : formatPrice(product.price);
const oldPriceLabel = onPromo ? formatPrice(product.price) : "";
const discount = onPromo ? discountPercent(product) : 0;
// El precio que viaja al mensaje de WhatsApp deja claro el precio de promo.
const waPrice = onPromo
  ? `${priceLabel} (PROMO, antes ${oldPriceLabel})`
  : priceLabel;
const firstColor = product.colors?.[0]?.name;
const hasPhoto = Boolean(product.images?.[0]) && product.images[0] !== PLACEHOLDER;
const ptype = productType(product) ?? "";
// Precio efectivo (numérico) y enlace directo a la foto para el mensaje.
const priceValue = onPromo ? (product.promoPrice as number) : product.price;
const imageUrl = hasPhoto ? new URL(product.images[0], Astro.site).href : undefined;

const href = productWhatsappUrl({
  name: product.name,
  reference: product.reference,
  price: waPrice,
  color: firstColor,
  image: imageUrl,
  url: productUrl,
});

// Datos que el buscador usa para filtrar (todo en minúsculas).
const haystack = [
  product.name,
  product.brand,
  product.reference,
  product.gender,
  ...(product.colors?.map((c) => c.name) ?? []),
  ...(product.tags ?? []),
]
  .filter(Boolean)
  .join(" ")
  .toLowerCase();

// Datos completos que usa el modal de detalle (se leen en cliente).
const detail = {
  id: product.id,
  name: product.name,
  brand: product.brand ?? "",
  reference: product.reference ?? "",
  price: priceLabel,
  priceValue,
  oldPrice: oldPriceLabel,
  discount,
  description: product.description ?? "",
  gender: product.gender ?? "",
  sizes: product.sizes ?? [],
  colors: (product.colors ?? []).map((c) => ({ name: c.name, hex: c.hex ?? "", img: c.img ?? "" })),
  images: hasPhoto ? product.images : [],
  url: productUrl ?? "",
  soldOut: Boolean(product.soldOut),
};
---

<li
  class="sus-prod"
  id={product.id}
  data-search={haystack}
  data-brand={product.brand ?? ""}
  data-gender={product.gender ?? ""}
  data-type={ptype}
  data-product={JSON.stringify(detail)}
>
  <article class="sus-prod__inner">
    <div class="sus-prod__media">
      {hasPhoto ? (
        <img src={product.images[0]} alt={product.name} width="600" height="600" loading="lazy" />
      ) : (
        <div class="sus-prod__placeholder" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="4" width="18" height="14" rx="2" />
            <circle cx="8.5" cy="9" r="1.6" />
            <path d="m4 17 5-5 4 3.5L17 12l3 3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Foto próximamente</span>
        </div>
      )}
      <button type="button" class="sus-prod__view" data-open-detail aria-label={`Ver detalles de ${product.name}`}>
        <span class="sus-prod__view-pill">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m21 21-4.3-4.3M11 8v6M8 11h6" stroke-linecap="round"></path>
          </svg>
          Ver detalles
        </span>
      </button>
      {onPromo && !product.soldOut && (
        <span class="sus-prod__badge sus-prod__badge--promo">-{discount}%</span>
      )}
      {product.featured && !product.soldOut && !onPromo && (
        <span class="sus-prod__badge">Destacado</span>
      )}
      {product.soldOut && <span class="sus-prod__badge sus-prod__badge--out">Agotado</span>}
    </div>

    <div class="sus-prod__body">
      {product.brand && <p class="sus-prod__brand">{product.brand}</p>}
      <h3 class="sus-prod__name">
        <button type="button" class="sus-prod__name-btn" data-open-detail>{product.name}</button>
      </h3>

      <div class="sus-prod__meta">
        {product.reference && <span class="sus-prod__ref">Ref. {product.reference}</span>}
        {product.gender && <span class="sus-prod__tag">{product.gender}</span>}
      </div>

      {product.colors && product.colors.length > 0 && (
        <div class="sus-prod__colors" role="group" aria-label="Colores disponibles">
          {product.colors.map((c, i) => (
            <button
              type="button"
              class={`sus-prod__swatch ${i === 0 ? "is-active" : ""}`}
              style={`--swatch:${c.hex ?? "#888"}`}
              data-color={c.name}
              data-img={c.img ?? ""}
              title={c.name}
              aria-label={c.name}
            ></button>
          ))}
        </div>
      )}

      <div class="sus-prod__footer">
        <span class="sus-prod__prices">
          <span class="sus-prod__price">{priceLabel}</span>
          {onPromo && <span class="sus-prod__price-old">{oldPriceLabel}</span>}
        </span>
        <div class="sus-prod__actions">
          <button type="button" class="sus-prod__add" data-add-cart aria-label={`Agregar ${product.name} al carrito`}>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="9" cy="20" r="1.3"></circle>
              <circle cx="18" cy="20" r="1.3"></circle>
              <path d="M2 3h3l2.4 12.1a1.5 1.5 0 0 0 1.5 1.2h8.4a1.5 1.5 0 0 0 1.5-1.2L22 7H6"></path>
            </svg>
            Agregar
          </button>
          <a
            class="sus-prod__cta"
            href={href}
            data-wa-cta
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"></path>
            </svg>
            Lo quiero
          </a>
        </div>
      </div>
    </div>
  </article>
</li>

<script>
  // Al elegir un color, lo resalta y reemplaza el color en el mensaje de WhatsApp.
  // Se ejecuta en cualquier página que use ProductCard (home, categorías, etc.).
  document.querySelectorAll<HTMLElement>(".sus-prod").forEach((card) => {
    const swatches = Array.from(
      card.querySelectorAll<HTMLButtonElement>(".sus-prod__swatch")
    );
    const cta = card.querySelector<HTMLAnchorElement>("[data-wa-cta]");
    const img = card.querySelector<HTMLImageElement>(".sus-prod__media img");

    // Agregar al carrito con el color activo y la foto que se está mostrando.
    const addBtn = card.querySelector<HTMLButtonElement>("[data-add-cart]");
    addBtn?.addEventListener("click", () => {
      let d: any = {};
      try {
        d = JSON.parse(card.dataset.product || "{}");
      } catch {
        /* noop */
      }
      const activeSwatch = card.querySelector<HTMLElement>(".sus-prod__swatch.is-active");
      const activeColor = activeSwatch?.dataset.color || d.colors?.[0]?.name || "";
      // Guardamos la ruta relativa (p. ej. /images/...) para que el thumbnail
      // cargue en cualquier origen/puerto; la URL absoluta se arma al pedir.
      const relImage = activeSwatch?.dataset.img || d.images?.[0] || "";
      document.dispatchEvent(
        new CustomEvent("sus:add-to-cart", {
          detail: {
            id: d.id,
            name: d.name,
            reference: d.reference,
            price: d.price,
            priceValue: d.priceValue,
            color: activeColor,
            size: "",
            image: relImage,
          },
        })
      );
    });

    swatches.forEach((sw) => {
      sw.addEventListener("click", () => {
        swatches.forEach((s) => s.classList.remove("is-active"));
        sw.classList.add("is-active");
        const color = sw.dataset.color || "";
        const photo = sw.dataset.img || "";
        if (img && photo) {
          img.src = photo;
          img.alt = color;
        }
        if (!cta || !color) return;
        try {
          const url = new URL(cta.href);
          const text = url.searchParams.get("text") || "";
          const updated = text.replace(/• Color: .*/u, `• Color: ${color}`);
          cta.href = `${url.origin}${url.pathname}?text=${encodeURIComponent(updated)}`;
        } catch {
          /* noop */
        }
      });
    });
  });
</script>

<style>
  .sus-prod {
    list-style: none;
  }
  .sus-prod__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }
  .sus-prod__inner:hover {
    border-color: var(--primary);
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }
  .sus-prod__media {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--bg-muted);
  }
  .sus-prod__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sus-prod__view {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 0.7rem;
    border: none;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.45), transparent 45%);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.18s ease;
  }
  .sus-prod__view-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.95);
    color: #111;
    font-size: 0.8rem;
    font-weight: 700;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
    transform: translateY(6px);
    transition: transform 0.18s ease;
  }
  .sus-prod__inner:hover .sus-prod__view,
  .sus-prod__view:focus-visible {
    opacity: 1;
  }
  .sus-prod__inner:hover .sus-prod__view-pill {
    transform: translateY(0);
  }
  @media (hover: none) {
    .sus-prod__view {
      opacity: 1;
      background: none;
      align-items: flex-start;
      justify-content: flex-end;
      padding: 0.55rem;
    }
    .sus-prod__view-pill {
      transform: none;
      padding: 0.4rem 0.55rem;
      font-size: 0;
      gap: 0;
    }
    .sus-prod__view-pill svg {
      width: 18px;
      height: 18px;
    }
  }
  .sus-prod__name-btn {
    margin: 0;
    padding: 0;
    background: none;
    border: none;
    font: inherit;
    color: inherit;
    text-align: left;
    cursor: pointer;
  }
  .sus-prod__name-btn:hover {
    color: var(--primary);
  }
  .sus-prod__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    height: 100%;
    background: var(--bg-muted);
    color: var(--text-muted);
  }
  .sus-prod__placeholder svg {
    color: var(--primary);
    opacity: 0.5;
  }
  .sus-prod__placeholder span {
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    opacity: 0.8;
  }
  .sus-prod__badge {
    position: absolute;
    top: 0.6rem;
    left: 0.6rem;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: var(--primary);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .sus-prod__badge--out {
    background: #52525b;
  }
  .sus-prod__badge--promo {
    background: linear-gradient(135deg, #ff3b3b, #e11d48);
    font-size: 0.8rem;
    box-shadow: 0 4px 12px rgba(225, 29, 72, 0.35);
  }
  .sus-prod__body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem;
    flex: 1;
  }
  .sus-prod__brand {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--primary);
  }
  .sus-prod__name {
    margin: 0;
    font-size: 1rem;
    line-height: 1.25;
  }
  .sus-prod__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }
  .sus-prod__ref,
  .sus-prod__tag {
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .sus-prod__tag {
    padding: 0.1rem 0.5rem;
    border: 1px solid var(--card-border);
    border-radius: 999px;
  }
  .sus-prod__colors {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.15rem;
  }
  .sus-prod__swatch {
    width: 1.15rem;
    height: 1.15rem;
    border-radius: 50%;
    background: var(--swatch);
    border: none;
    box-shadow: 0 0 0 1px var(--card-border);
    cursor: pointer;
    padding: 0;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  .sus-prod__swatch:hover {
    transform: scale(1.15);
  }
  .sus-prod__swatch.is-active {
    box-shadow: 0 0 0 2px var(--card-bg), 0 0 0 3.5px var(--primary);
  }
  .sus-prod__footer {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.6rem;
    margin-top: auto;
    padding-top: 0.75rem;
  }
  .sus-prod__prices {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .sus-prod__price {
    font-family: var(--font-display);
    font-size: 1.35rem;
    letter-spacing: 0.02em;
  }
  .sus-prod__price-old {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: line-through;
    text-decoration-color: #e11d48;
  }
  .sus-prod__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: 0.5rem;
  }
  .sus-prod__add {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    flex: 1 1 auto;
    min-width: 0;
    padding: 0.6rem 0.7rem;
    border-radius: 999px;
    background: var(--card-bg);
    color: var(--text);
    border: 1.5px solid var(--card-border);
    font-weight: 700;
    font-size: 0.82rem;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 0.12s ease, color 0.12s ease, transform 0.12s ease;
  }
  .sus-prod__add:hover {
    border-color: var(--primary);
    color: var(--primary);
    transform: translateY(-1px);
  }
  .sus-prod__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.6rem 0.9rem;
    border-radius: 999px;
    background: #25d366;
    color: #fff;
    font-weight: 700;
    font-size: 0.85rem;
    text-decoration: none;
    white-space: nowrap;
    flex: 1 1 auto;
    min-width: 0;
    transition: transform 0.12s ease, filter 0.12s ease;
  }
  .sus-prod__cta:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }
  /* En tarjetas muy anchas el precio y los botones caben en una sola fila. */
  @media (min-width: 1500px) {
    .sus-prod__footer {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }
  }
</style>
