---
import type { CategorySlug } from "../data/products";

interface Props {
  slug: CategorySlug;
  size?: number;
}

const { slug, size = 24 } = Astro.props;

// Íconos de línea por categoría (estilo consistente con el sitio).
const icons: Record<CategorySlug, string> = {
  tenis: `<path d="M4 16v-2.4C4 11.5 3 10.5 3 8c0-2.7 1.5-6 4.5-6C9.4 2 10 3.8 10 5.5c0 3.1-2 5.7-2 8.7V16a2 2 0 1 1-4 0Z"/><path d="M20 20v-2.4c0-2.1 1-3.1 1-5.6 0-2.7-1.5-6-4.5-6C14.6 6 14 7.8 14 9.5c0 3.1 2 5.7 2 8.7V20a2 2 0 1 0 4 0Z"/><path d="M16 17h4"/><path d="M4 13h4"/>`,
  ropa: `<path d="M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"/>`,
  deportivo: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
  accesorios: `<path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r="1.2" fill="currentColor" stroke="none"/>`,
  hogar: `<path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/>`,
  cuidado: `<rect width="4" height="4" x="14" y="4" rx="1"/><path d="M5 4h.01"/><path d="M9 6h.01"/><path d="M5 8h.01"/><path d="M9 10h.01"/><path d="M18 12.5A2 2 0 0 1 19 14v6a1 1 0 0 1-1 1h-7a1 1 0 0 1-1-1v-6a2 2 0 0 1 1-1.7l1-.6V10a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v1.7z"/>`,
};
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={icons[slug] ?? ""}
/>
