---
import ProductCard from "./ProductCard.astro";
import { productsOnPromo } from "../data/products";

const promos = productsOnPromo();
const productUrlFor = (slug: string, id: string) =>
  new URL(`/categoria/${slug}#${id}`, Astro.site).toString();
---

{promos.length > 0 && (
  <section class="sus-promos" id="promociones">
    <div class="sus-container">
      <div class="sus-promos__head">
        <div class="sus-promos__heading">
          <span class="sus-promos__flame" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
              <path d="M12 2s4 3.5 4 8a4 4 0 0 1-8 0c0-1 .3-1.8.6-2.4C7 8.5 6 10.4 6 13a6 6 0 0 0 12 0c0-5.5-6-11-6-11Z"/>
            </svg>
          </span>
          <div>
            <p class="sus-promos__eyebrow">Ofertas por tiempo limitado</p>
            <h2 class="sus-promos__title">Promociones 🔥</h2>
          </div>
        </div>
        <p class="sus-promos__sub">Precios de remate mientras dure el inventario. ¡Aprovecha!</p>
      </div>

      <ul class="sus-promos__grid">
        {promos.map((product) => (
          <ProductCard product={product} productUrl={productUrlFor(product.category, product.id)} />
        ))}
      </ul>
    </div>
  </section>
)}

<style>
  .sus-promos {
    position: relative;
    padding: 3rem 0;
    background:
      radial-gradient(120% 120% at 0% 0%, rgba(225, 29, 72, 0.14), transparent 55%),
      radial-gradient(120% 120% at 100% 0%, rgba(255, 122, 0, 0.12), transparent 55%),
      var(--bg);
    border-top: 1px solid var(--card-border);
    border-bottom: 1px solid var(--card-border);
  }
  .sus-promos__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .sus-promos__heading {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .sus-promos__flame {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 14px;
    color: #fff;
    background: linear-gradient(135deg, #ff7a00, #e11d48);
    box-shadow: 0 8px 22px rgba(225, 29, 72, 0.35);
    flex: 0 0 auto;
  }
  .sus-promos__eyebrow {
    margin: 0;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #e11d48;
  }
  .sus-promos__title {
    margin: 0.1rem 0 0;
    font-family: var(--font-display, inherit);
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    line-height: 1.05;
  }
  .sus-promos__sub {
    margin: 0;
    max-width: 26rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .sus-promos__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  @media (min-width: 720px) {
    .sus-promos__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  @media (min-width: 1000px) {
    .sus-promos__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
