---
// Carrito de compras. Se monta una vez por página. Guarda en localStorage y
// arma un único pedido de WhatsApp con todos los productos (foto, ref, color,
// talla, cantidad y total). Las tarjetas/modal agregan productos disparando el
// evento `sus:add-to-cart` con los datos del producto.
---

<div class="cart" data-cart hidden>
  <div class="cart__backdrop" data-cart-close></div>
  <aside class="cart__panel" role="dialog" aria-modal="true" aria-label="Tu carrito">
    <header class="cart__head">
      <div>
        <p class="cart__eyebrow">Tu pedido</p>
        <h2 class="cart__title">Carrito</h2>
      </div>
      <button type="button" class="cart__close" data-cart-close aria-label="Cerrar carrito">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"></path>
        </svg>
      </button>
    </header>

    <div class="cart__items" data-cart-items></div>

    <div class="cart__empty" data-cart-empty>
      <svg viewBox="0 0 24 24" width="46" height="46" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
        <circle cx="9" cy="20" r="1.4"></circle>
        <circle cx="18" cy="20" r="1.4"></circle>
        <path d="M2 3h3l2.4 12.1a1.5 1.5 0 0 0 1.5 1.2h8.4a1.5 1.5 0 0 0 1.5-1.2L22 7H6" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
      <p class="cart__empty-title">Tu carrito está vacío</p>
      <p class="cart__empty-sub">Agrega lo que te guste y pídelo todo junto por WhatsApp.</p>
    </div>

    <footer class="cart__foot" data-cart-foot hidden>
      <div class="cart__totalrow">
        <span>Total estimado</span>
        <strong data-cart-total></strong>
      </div>
      <a class="cart__order" data-cart-order target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"></path>
        </svg>
        Pedir todo por WhatsApp
      </a>
      <button type="button" class="cart__clear" data-cart-clear>Vaciar carrito</button>
      <p class="cart__note">Te enviamos el detalle con fotos. Confirmamos stock y envío por chat.</p>
    </footer>
  </aside>
</div>

<script>
  import { buildCartMessage, cartCount, cartTotal, formatCOP, type CartItem } from "../lib/cart";
  import { whatsappUrl } from "../lib/whatsapp";

  function initCart() {
    const root = document.querySelector<HTMLElement>("[data-cart]");
    if (!root) return;

    const itemsEl = root.querySelector<HTMLElement>("[data-cart-items]")!;
    const emptyEl = root.querySelector<HTMLElement>("[data-cart-empty]")!;
    const footEl = root.querySelector<HTMLElement>("[data-cart-foot]")!;
    const totalEl = root.querySelector<HTMLElement>("[data-cart-total]")!;
    const orderEl = root.querySelector<HTMLAnchorElement>("[data-cart-order]")!;

    const STORAGE_KEY = "sus-cart-v1";
    let items: CartItem[] = load();

    function load(): CartItem[] {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw);
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    }

    function save() {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
      } catch {
        /* noop */
      }
    }

    function esc(s: string): string {
      return String(s).replace(/[&<>"]/g, (c) =>
        c === "&" ? "&amp;" : c === "<" ? "&lt;" : c === ">" ? "&gt;" : "&quot;"
      );
    }

    // Convierte una imagen guardada (relativa o absoluta) a ruta relativa al
    // origen actual para que el thumbnail cargue aunque cambie puerto/dominio.
    function thumbRelative(src?: string): string {
      if (!src) return "";
      try {
        return new URL(src, location.origin).pathname;
      } catch {
        return src;
      }
    }

    function updateBadges() {
      const count = cartCount(items);
      document.querySelectorAll<HTMLElement>("[data-cart-count]").forEach((b) => {
        b.textContent = String(count);
        b.hidden = count === 0;
      });
    }

    function render() {
      itemsEl.innerHTML = "";
      const has = items.length > 0;
      emptyEl.hidden = has;
      footEl.hidden = !has;

      items.forEach((it) => {
        const row = document.createElement("div");
        row.className = "cart-item";
        row.dataset.key = it.key;
        const meta = [it.color, it.size ? `Talla ${it.size}` : ""].filter(Boolean).join(" · ");
        // Mostramos siempre por ruta relativa al origen actual. Así los carritos
        // guardados con URLs absolutas viejas (otro puerto/origen) no se rompen.
        const thumbSrc = thumbRelative(it.image);
        row.innerHTML = `
          <div class="cart-item__media">
            ${
              thumbSrc
                ? `<img src="${esc(thumbSrc)}" alt="${esc(it.name)}" loading="lazy" />`
                : `<span class="cart-item__noimg">Sin foto</span>`
            }
          </div>
          <div class="cart-item__info">
            <p class="cart-item__name">${esc(it.name)}</p>
            ${meta ? `<p class="cart-item__meta">${esc(meta)}</p>` : ""}
            ${it.price ? `<p class="cart-item__price">${esc(it.price)}</p>` : ""}
            <div class="cart-item__qty" role="group" aria-label="Cantidad">
              <button type="button" data-qty-dec aria-label="Quitar uno">−</button>
              <span class="cart-item__qtyval">${it.qty}</span>
              <button type="button" data-qty-inc aria-label="Agregar uno">+</button>
            </div>
          </div>
          <button type="button" class="cart-item__remove" data-remove aria-label="Quitar del carrito">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"></path>
            </svg>
          </button>`;
        itemsEl.appendChild(row);
      });

      const total = cartTotal(items);
      totalEl.textContent = total > 0 ? formatCOP(total) : "A confirmar";
      // Para el mensaje, la foto debe ser una URL absoluta del origen actual
      // (incluso si se guardó con otro puerto/dominio antiguo).
      const itemsForMsg = items.map((it) => {
        const rel = thumbRelative(it.image);
        return { ...it, image: rel ? new URL(rel, location.origin).href : "" };
      });
      orderEl.href = has ? whatsappUrl(buildCartMessage(itemsForMsg)) : "#";

      updateBadges();
      save();
    }

    function addItem(raw: Partial<CartItem>) {
      const id = raw.id || "";
      const color = raw.color || "";
      const size = raw.size || "";
      const key = `${id}|${color}|${size}`;
      const existing = items.find((it) => it.key === key);
      if (existing) {
        existing.qty += 1;
      } else {
        items.push({
          key,
          id,
          name: raw.name || "Producto",
          reference: raw.reference || "",
          price: raw.price || "",
          priceValue: typeof raw.priceValue === "number" ? raw.priceValue : undefined,
          color,
          size,
          image: raw.image || "",
          qty: 1,
        });
      }
      render();
      open();
      pulse();
    }

    function setQty(key: string, delta: number) {
      const it = items.find((x) => x.key === key);
      if (!it) return;
      it.qty += delta;
      if (it.qty <= 0) items = items.filter((x) => x.key !== key);
      render();
    }

    function removeItem(key: string) {
      items = items.filter((x) => x.key !== key);
      render();
    }

    function clear() {
      items = [];
      render();
    }

    let pulseTimer = 0;
    function pulse() {
      document.querySelectorAll<HTMLElement>("[data-cart-btn]").forEach((b) => {
        b.classList.add("is-bump");
      });
      window.clearTimeout(pulseTimer);
      pulseTimer = window.setTimeout(() => {
        document.querySelectorAll<HTMLElement>("[data-cart-btn]").forEach((b) => {
          b.classList.remove("is-bump");
        });
      }, 350);
    }

    function open() {
      root.hidden = false;
      document.body.style.overflow = "hidden";
      requestAnimationFrame(() => root.classList.add("is-open"));
    }
    function close() {
      root.classList.remove("is-open");
      document.body.style.overflow = "";
      window.setTimeout(() => {
        root.hidden = true;
      }, 220);
    }

    // Abrir desde el botón del header (delegación, el header es otro componente).
    document.addEventListener("click", (e) => {
      const opener = (e.target as HTMLElement).closest("[data-cart-open]");
      if (opener) {
        e.preventDefault();
        open();
      }
    });

    // Agregar al carrito desde tarjetas / modal.
    document.addEventListener("sus:add-to-cart", (e) => {
      addItem((e as CustomEvent).detail || {});
    });

    // Controles dentro del carrito.
    itemsEl.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const row = target.closest<HTMLElement>(".cart-item");
      if (!row) return;
      const key = row.dataset.key || "";
      if (target.closest("[data-qty-inc]")) setQty(key, 1);
      else if (target.closest("[data-qty-dec]")) setQty(key, -1);
      else if (target.closest("[data-remove]")) removeItem(key);
    });

    root.querySelectorAll<HTMLElement>("[data-cart-close]").forEach((el) =>
      el.addEventListener("click", close)
    );
    root.querySelector<HTMLButtonElement>("[data-cart-clear]")?.addEventListener("click", clear);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !root.hidden) close();
    });

    render();
  }

  initCart();
</script>

<style is:global>
  /* Prefijado .cart / .cart-item porque las filas se crean en JS. */
  .cart {
    position: fixed;
    inset: 0;
    z-index: 1100;
  }
  .cart[hidden] {
    display: none;
  }
  .cart [hidden] {
    display: none !important;
  }
  .cart__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 14, 0.6);
    backdrop-filter: blur(3px);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .cart.is-open .cart__backdrop {
    opacity: 1;
  }
  .cart__panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: min(420px, 100%);
    display: flex;
    flex-direction: column;
    background: var(--card-bg, #fff);
    color: var(--text, #111);
    border-left: 1px solid var(--card-border, #e5e7eb);
    box-shadow: -20px 0 60px rgba(0, 0, 0, 0.35);
    transform: translateX(100%);
    transition: transform 0.24s ease;
  }
  .cart.is-open .cart__panel {
    transform: translateX(0);
  }
  .cart__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    border-bottom: 1px solid var(--card-border, #e5e7eb);
  }
  .cart__eyebrow {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--primary, #2563eb);
  }
  .cart__title {
    margin: 0.1rem 0 0;
    font-family: var(--font-display, inherit);
    font-size: 1.5rem;
    line-height: 1;
  }
  .cart__close {
    display: grid;
    place-items: center;
    width: 2.3rem;
    height: 2.3rem;
    border-radius: 50%;
    border: 1px solid var(--card-border, #e5e7eb);
    background: transparent;
    color: var(--text, #111);
    cursor: pointer;
    flex: 0 0 auto;
    transition: border-color 0.12s ease, color 0.12s ease;
  }
  .cart__close:hover {
    border-color: var(--primary, #2563eb);
    color: var(--primary, #2563eb);
  }
  .cart__items {
    flex: 1;
    overflow-y: auto;
    padding: 0.75rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .cart-item {
    display: grid;
    grid-template-columns: 4.25rem 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--card-border, #e5e7eb);
  }
  .cart-item__media {
    width: 4.25rem;
    height: 4.25rem;
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-muted, #f4f4f5);
    display: grid;
    place-items: center;
  }
  .cart-item__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cart-item__noimg {
    font-size: 0.62rem;
    color: var(--text-muted, #a1a1aa);
    text-align: center;
  }
  .cart-item__info {
    min-width: 0;
  }
  .cart-item__name {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.2;
  }
  .cart-item__meta {
    margin: 0.15rem 0 0;
    font-size: 0.76rem;
    color: var(--text-muted, #71717a);
  }
  .cart-item__price {
    margin: 0.2rem 0 0;
    font-size: 0.86rem;
    font-weight: 700;
    color: var(--primary, #2563eb);
  }
  .cart-item__qty {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.4rem;
  }
  .cart-item__qty button {
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 7px;
    border: 1px solid var(--card-border, #e5e7eb);
    background: var(--card-bg, #fff);
    color: var(--text, #111);
    font-size: 1.05rem;
    line-height: 1;
    cursor: pointer;
  }
  .cart-item__qty button:hover {
    border-color: var(--primary, #2563eb);
    color: var(--primary, #2563eb);
  }
  .cart-item__qtyval {
    min-width: 1.2rem;
    text-align: center;
    font-weight: 700;
    font-size: 0.9rem;
  }
  .cart-item__remove {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: var(--text-muted, #a1a1aa);
    cursor: pointer;
    align-self: flex-start;
  }
  .cart-item__remove:hover {
    color: #e11d48;
    background: rgba(225, 29, 72, 0.1);
  }
  .cart__empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 2rem;
    text-align: center;
    color: var(--text-muted, #71717a);
  }
  .cart__empty svg {
    color: var(--primary, #2563eb);
    opacity: 0.5;
  }
  .cart__empty-title {
    margin: 0.5rem 0 0;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text, #111);
  }
  .cart__empty-sub {
    margin: 0;
    max-width: 18rem;
    font-size: 0.85rem;
  }
  .cart__foot {
    padding: 1rem 1.25rem 1.25rem;
    border-top: 1px solid var(--card-border, #e5e7eb);
    background: var(--card-bg, #fff);
  }
  .cart__totalrow {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    font-size: 0.92rem;
    color: var(--text-muted, #71717a);
  }
  .cart__totalrow strong {
    font-family: var(--font-display, inherit);
    font-size: 1.45rem;
    color: var(--text, #111);
  }
  .cart__order {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.95rem 1.2rem;
    border-radius: 12px;
    background: #25d366;
    color: #fff;
    font-weight: 800;
    font-size: 1rem;
    text-decoration: none;
    transition: transform 0.12s ease, filter 0.12s ease;
  }
  .cart__order:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }
  .cart__clear {
    display: block;
    width: 100%;
    margin-top: 0.6rem;
    padding: 0.5rem;
    border: none;
    background: transparent;
    color: var(--text-muted, #71717a);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
  }
  .cart__clear:hover {
    color: #e11d48;
  }
  .cart__note {
    margin: 0.5rem 0 0;
    font-size: 0.74rem;
    color: var(--text-muted, #a1a1aa);
    text-align: center;
  }
</style>
