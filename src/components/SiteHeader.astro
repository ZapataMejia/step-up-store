---
import Logo from "./Logo.astro";
import type { ThemeId } from "../data/themes";
import { store } from "../data/store";

interface Props {
  themeId?: ThemeId;
}

const { themeId = "v1" } = Astro.props;

const links = [
  { href: "/#promociones", label: "Promociones" },
  { href: "/#categorias", label: "Categorías" },
  { href: "/#catalogos", label: "Destacados" },
  { href: "/#marcas", label: "Marcas" },
  { href: "/#como-comprar", label: "Cómo comprar" },
  { href: "/#pagos", label: "Pagos" },
];
---

<header class="sus-header">
  <div class="sus-container sus-header__inner">
    <a class="sus-header__brand" href="/" aria-label={`${store.name} ${store.nameAccent} — inicio`}>
      <Logo size="sm" />
      <span class="sus-header__wordmark">
        <span class="sus-header__name">{store.name}</span>
        <span class="sus-header__accent">{store.nameAccent}</span>
      </span>
    </a>
    <nav class="sus-header__nav" aria-label="Principal">
      {links.map((l) => (
        <a href={l.href}>{l.label}</a>
      ))}
    </nav>
    <div class="sus-header__actions">
      <button
        type="button"
        class="sus-cart-btn"
        data-cart-open
        data-cart-btn
        aria-label="Abrir carrito"
        title="Tu carrito"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="9" cy="20" r="1.4"></circle>
          <circle cx="18" cy="20" r="1.4"></circle>
          <path d="M2 3h3l2.4 12.1a1.5 1.5 0 0 0 1.5 1.2h8.4a1.5 1.5 0 0 0 1.5-1.2L22 7H6"></path>
        </svg>
        <span class="sus-cart-btn__count" data-cart-count hidden>0</span>
      </button>
      <button
        type="button"
        class="sus-mode-toggle"
        data-mode-toggle
        aria-label="Cambiar entre modo claro y oscuro"
        title="Cambiar modo claro / oscuro"
      >
        <svg class="sus-mode-toggle__sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
        </svg>
        <svg class="sus-mode-toggle__moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
      <a class="sus-btn sus-btn--primary sus-header__cta" href="/#categorias">
        Ver catálogo
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-mode-toggle]");
  toggle?.addEventListener("click", () => {
    const current = document.documentElement.dataset.mode === "light" ? "light" : "dark";
    const next = current === "light" ? "dark" : "light";
    document.documentElement.dataset.mode = next;
    try {
      localStorage.setItem("sus-mode", next);
    } catch {
      /* noop */
    }
  });
</script>

<style>
  .sus-header {
    position: sticky;
    top: 0;
    z-index: 40;
    height: var(--header-h);
    background: var(--header-bg);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--header-border);
    color: var(--header-text);
  }
  .sus-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: var(--header-h);
  }
  .sus-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: inherit;
  }
  .sus-header__wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .sus-header__name {
    font-family: var(--font-display);
    font-size: 1.35rem;
    letter-spacing: 0.04em;
  }
  .sus-header__accent {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    color: var(--primary);
    text-transform: uppercase;
  }
  .sus-header__nav {
    display: none;
    gap: 1.25rem;
  }
  .sus-header__nav a {
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .sus-header__nav a:hover {
    color: var(--primary);
  }
  html.theme-v2 .sus-header__nav a,
  html.theme-v3 .sus-header__nav a {
    color: var(--hero-muted);
  }
  .sus-header__actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .sus-cart-btn {
    position: relative;
    display: grid;
    place-items: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 50%;
    border: 1px solid var(--header-border);
    background: transparent;
    color: var(--header-text);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }
  .sus-cart-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
    transform: translateY(-1px);
  }
  .sus-cart-btn.is-bump {
    animation: sus-cart-bump 0.35s ease;
  }
  @keyframes sus-cart-bump {
    0% { transform: scale(1); }
    40% { transform: scale(1.22); }
    100% { transform: scale(1); }
  }
  .sus-cart-btn__count {
    position: absolute;
    top: -0.35rem;
    right: -0.35rem;
    min-width: 1.2rem;
    height: 1.2rem;
    padding: 0 0.3rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: var(--primary);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 800;
    line-height: 1;
  }
  .sus-cart-btn__count[hidden] {
    display: none;
  }
  .sus-mode-toggle {
    display: grid;
    place-items: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 50%;
    border: 1px solid var(--header-border);
    background: transparent;
    color: var(--header-text);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }
  .sus-mode-toggle:hover {
    border-color: var(--primary);
    color: var(--primary);
    transform: translateY(-1px);
  }
  /* Muestra el ícono según el modo actual: en oscuro ofrece pasar a claro (sol). */
  .sus-mode-toggle__sun {
    display: block;
  }
  .sus-mode-toggle__moon {
    display: none;
  }
  html[data-mode="light"] .sus-mode-toggle__sun {
    display: none;
  }
  html[data-mode="light"] .sus-mode-toggle__moon {
    display: block;
  }
  .sus-header__cta {
    font-size: 0.82rem;
    padding: 0.65rem 1rem;
    white-space: nowrap;
  }
  @media (min-width: 860px) {
    .sus-header__nav {
      display: flex;
    }
  }
  @media (max-width: 480px) {
    .sus-header__wordmark {
      display: none;
    }
  }
</style>
