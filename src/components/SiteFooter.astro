---
import { store, developer } from "../data/store";
import { whatsappUrl } from "../lib/whatsapp";

const year = new Date().getFullYear();
const wa = whatsappUrl();
---

<footer class="sus-footer">
  <div class="sus-container sus-footer__grid">
    <div>
      <p class="sus-footer__brand">
        {store.name} <span>{store.nameAccent}</span>
      </p>
      <p class="sus-footer__tag">{store.tagline}</p>
    </div>
    <div>
      <p class="sus-footer__label">Contacto</p>
      <ul>
        <li>
          <a href={wa} target="_blank" rel="noopener noreferrer">WhatsApp {store.whatsappDisplay}</a>
        </li>
        <li class="sus-footer__muted">{store.shippingNote}</li>
      </ul>
    </div>
    <div>
      <p class="sus-footer__label">Enlaces</p>
      <ul>
        <li><a href="/#categorias">Categorías</a></li>
        <li><a href="/#catalogos">Destacados</a></li>
        <li><a href="/#como-comprar">Cómo comprar</a></li>
        <li><a href="/#pagos">Pagos</a></li>
      </ul>
    </div>
    <div>
      <p class="sus-footer__label">Síguenos</p>
      <ul class="sus-footer__social">
        <li>
          <a href={store.instagramUrl} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
            </svg>
            Instagram
          </a>
        </li>
        <li>
          <a href={wa} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"></path>
            </svg>
            WhatsApp
          </a>
        </li>
      </ul>
      <p class="sus-footer__handle">{store.instagramHandle}</p>
    </div>
  </div>
  <div class="sus-footer__bottom sus-container">
    <p class="sus-footer__copy">© {year} {store.name} {store.nameAccent}. Todos los derechos reservados.</p>
    <p class="sus-footer__credit">
      Diseñada y desarrollada por
      <a href={developer.url} target="_blank" rel="noopener noreferrer">{developer.name}</a>
    </p>
  </div>
</footer>

<style>
  .sus-footer {
    padding: 2.5rem 0 1.5rem;
    background: var(--footer-bg);
    color: var(--footer-text);
  }
  .sus-footer__grid {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 560px) {
    .sus-footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 880px) {
    .sus-footer__grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }
  .sus-footer__brand {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  html.theme-v4 .sus-footer__brand {
    text-transform: none;
  }
  .sus-footer__brand span {
    color: var(--primary);
  }
  .sus-footer__tag {
    margin: 0.35rem 0 0;
    color: #94a3b8;
    font-size: 0.9rem;
  }
  .sus-footer__label {
    margin: 0 0 0.5rem;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94a3b8;
  }
  .sus-footer ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .sus-footer a {
    color: #f8fafc;
    text-decoration: none;
    font-weight: 500;
  }
  .sus-footer a:hover {
    color: var(--primary);
  }
  .sus-footer li + li {
    margin-top: 0.35rem;
  }
  .sus-footer__muted {
    color: #64748b;
    font-size: 0.9rem;
  }
  .sus-footer__social a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .sus-footer__social svg {
    flex-shrink: 0;
  }
  .sus-footer__handle {
    margin: 0.6rem 0 0;
    font-size: 0.85rem;
    color: #64748b;
  }
  .sus-footer__bottom {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .sus-footer__copy {
    margin: 0;
    font-size: 0.8rem;
    color: #64748b;
  }
  .sus-footer__credit {
    margin: 0;
    font-size: 0.8rem;
    color: #64748b;
  }
  .sus-footer__credit a {
    color: #cbd5e1;
    font-weight: 700;
    text-decoration: none;
  }
  .sus-footer__credit a:hover {
    color: var(--primary);
    text-decoration: underline;
  }
</style>
