---
import { catalogLinks } from "../data/store";
import { whatsappUrl, defaultOrderMessage } from "../lib/whatsapp";

const wa = whatsappUrl(defaultOrderMessage);
const hasLinks = catalogLinks.length > 0;
---

<section class="sus-section" id="catalogos">
  <div class="sus-container">
    <p class="sus-section__eyebrow">Catálogos</p>
    <h2 class="sus-section__title">Mira lo disponible</h2>

    {hasLinks ? (
      <ul class="sus-catalogs">
        {catalogLinks.map((c) => (
          <li>
            <a class="sus-btn sus-btn--primary" href={c.href} target="_blank" rel="noopener noreferrer">
              {c.label}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="sus-catalogs__pending">
        <p class="sus-section__lead">
          Los enlaces a los catálogos digitales se publicarán aquí en cuanto nos los compartan. Mientras
          tanto, pide por WhatsApp con foto del catálogo impreso o describe lo que buscas.
        </p>
        <a class="sus-btn sus-btn--outline" href={wa} target="_blank" rel="noopener noreferrer">
          Pedir por WhatsApp
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .sus-catalogs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .sus-catalogs__pending {
    margin-top: 1rem;
    padding: 1.5rem;
    border: 2px dashed var(--gray-200);
    border-radius: var(--radius);
    background: var(--gray-50);
  }

  .sus-catalogs__pending .sus-section__lead {
    margin-bottom: 1.25rem;
  }
</style>
