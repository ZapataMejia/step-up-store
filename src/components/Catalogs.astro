---
import ProductCard from "./ProductCard.astro";
import { products } from "../data/products";

const featured = products.filter((p) => p.featured && !p.soldOut).slice(0, 4);
const productUrlFor = (slug: string, id: string) =>
  new URL(`/categoria/${slug}#${id}`, Astro.site).toString();
---

{featured.length > 0 && (
  <section class="sus-section" id="catalogos">
    <div class="sus-container">
      <div class="sus-featured__head">
        <div>
          <p class="sus-section__eyebrow">Destacados</p>
          <h2 class="sus-section__title">Lo más pedido</h2>
        </div>
        <a class="sus-featured__all" href="/#categorias">Ver todo el catálogo →</a>
      </div>

      <ul class="sus-featured__grid">
        {featured.map((product) => (
          <ProductCard product={product} productUrl={productUrlFor(product.category, product.id)} />
        ))}
      </ul>
    </div>
  </section>
)}

<style>
  .sus-featured__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .sus-featured__all {
    font-weight: 800;
    color: var(--primary);
    text-decoration: none;
    font-size: 0.95rem;
    white-space: nowrap;
  }
  .sus-featured__all:hover {
    text-decoration: underline;
  }
  .sus-featured__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  @media (min-width: 720px) {
    .sus-featured__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .sus-featured__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
