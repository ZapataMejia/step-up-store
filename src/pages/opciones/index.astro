---
import Layout from "../../layouts/Layout.astro";
import { themes } from "../../data/themes";
import { store } from "../../data/store";
---

<Layout title={`${store.name} ${store.nameAccent} · Elegir diseño`} description="Cuatro propuestas de sitio web. Color de marca: azul.">
  <main class="picker">
    <div class="sus-container">
      <a class="picker__back" href="/">← Ver sitio en producción (urbano impacto)</a>
      <p class="picker__brand">{store.name} {store.nameAccent}</p>
      <h1 class="picker__title">Elige el estilo de la página</h1>
      <p class="picker__lead">
        Cuatro propuestas con <strong>azul</strong> de marca. La opción 2 (urbano impacto) está en la página de inicio;
        aquí puedes comparar las demás.
      </p>

      <div class="picker__grid">
        {themes.map((t) => (
          <a
            class:list={["picker__card", t.id === "v2" && "picker__card--featured"]}
            href={t.id === "v2" ? "/" : `/opciones/${t.slug}`}
          >
            {t.id === "v2" ? <span class="picker__tag">En producción</span> : t.tag ? <span class="picker__tag">{t.tag}</span> : null}
            <h2>{t.name}</h2>
            <p>{t.desc}</p>
            <div class="picker__swatch" aria-hidden="true">
              <span style="background:#1d4ed8"></span>
              <span style="background:#ffffff;border:1px solid #e2e8f0"></span>
              <span style={t.id === "v2" || t.id === "v3" ? "background:#0a0a0a" : "background:#f8fafc"}></span>
            </div>
            <span class="picker__link">{t.id === "v2" ? "Abrir inicio →" : "Ver propuesta →"}</span>
          </a>
        ))}
      </div>

      <p class="picker__banner">
        Elegida por el cliente: <strong>Urbano impacto</strong> — en <a href="/">la portada</a>.
      </p>
    </div>
  </main>
</Layout>

<style>
  .picker__tag--live {
    background: #0a0a0a;
    margin-left: 0.35rem;
  }
  .picker__banner a {
    color: #fff;
    font-weight: 800;
  }
</style>
